<odoo>
    <record id="action_product_template_sl" model="ir.actions.act_window">
        <field name="name">Products for Sales Layer</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">[('is_sl_sync', '=', True)]</field>
        <field name="context">{'default_is_sl_sync': True}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Manage your Sales Layer PIM Products here.
            </p>
            <p>
                Select products to be synchronized with Sales Layer API v2.
            </p>
        </field>
    </record>

    <menuitem id="menu_sl_root" 
              name="Sales Layer" 
              web_icon="odoo_sales_layer_connector,static/description/icon.png"
              groups="stock.group_stock_manager"
              sequence="100"/>

    <menuitem id="menu_sl_products" 
              name="Products" 
              parent="menu_sl_root" 
              action="action_product_template_sl"
              sequence="10"/>

    <menuitem id="menu_sl_config" 
              name="Configuration" 
              parent="menu_sl_root" 
              sequence="100"/>

    <menuitem id="menu_sl_settings" 
              name="Settings" 
              parent="menu_sl_config" 
              action="base_setup.action_general_configuration"
              context="{'module': 'odoo_sales_layer_connector'}"
              groups="base.group_system"
              sequence="10"/>
</odoo>
